#!/usr/bin/env bash
set -euo pipefail

# List unassigned changes with their CLI IDs, ready for use with but commit/amend.
#
# Usage: but-unassigned [--json]
#
# Output: one line per change — "cliId  changeType  filePath"

if [[ "${1:-}" == "--help" ]]; then
    echo "Usage: but-unassigned [--json]"
    echo
    echo "  List unassigned (uncommitted, unbranched) changes with CLI IDs."
    echo "  --json  Output raw JSON array"
    exit 0
fi

status_json=$(but status --json 2>/dev/null)

if [[ "${1:-}" == "--json" ]]; then
    echo "$status_json" | jq '.unassignedChanges'
    exit 0
fi

echo "$status_json" | jq -r '
  .unassignedChanges[] |
  "\(.cliId)\t\(.changeType)\t\(.filePath)"
' 2>/dev/null | column -t -s$'\t' || echo "(none)"
