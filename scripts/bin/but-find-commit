#!/usr/bin/env bash
set -euo pipefail

# Find a commit's CLI ID and full SHA by searching commit messages.
#
# Usage: but-find-commit <pattern>
#
# Searches all applied branches for commits whose message contains <pattern>
# (case-insensitive substring match).  Prints: cliId  commitId  branchName  message

if [[ $# -lt 1 ]] || [[ "${1:-}" == "--help" ]]; then
    echo "Usage: but-find-commit <pattern>"
    echo
    echo "  Search commit messages across all applied branches."
    echo "  Output: cliId  commitId  branchName  message"
    exit 0
fi

PATTERN="$1"

but status --json 2>/dev/null | python3 -c "
import json, sys
pattern = sys.argv[1].lower()
data = json.load(sys.stdin)
for stack in data.get('stacks', []):
    for branch in stack.get('branches', []):
        for commit in branch.get('commits', []):
            if pattern in commit['message'].lower():
                print(f'{commit[\"cliId\"]}\t{commit[\"commitId\"][:12]}\t{branch[\"name\"]}\t{commit[\"message\"].splitlines()[0][:60]}')
" "$PATTERN" | column -t -s$'\t'
