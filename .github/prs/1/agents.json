    "s13": {
      "id": "s13",
      "folder": "s12.s13/feat/wasi-first-compile",
      "branch": "pr1/s12.s13/feat/wasi-first-compile",
      "anchor": "pr1/s02-s11.s12/feat/wasi-gix-features",
      "deps": ["s12"],
      "description": "Fix remaining compile errors",
      "size": "M",
      "commit": "feat: first successful wasm32-wasip2 compilation",
      "crates": ["*"],
      "files": [],
      "note": "Scope determined by actual compile errors — files list populated during implementation"
    },
    "s14": {
      "id": "s14",
      "folder": "s13.s14/feat/wasi-runtime-host",
