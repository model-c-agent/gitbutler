{
  "$schema": "https://claude.ai/agents/v1",
  "pr": 1,
  "mainBranch": "feat/wasi",
  "target": "master",
  "workspace": {
    "mode": "shared-fs",
    "note": "All agents share the same filesystem. Isolation is at the git branch level via but."
  },
  "coordinator": {
    "role": "orchestrator",
    "instructions": "AGENT.md",
    "context": ["../PR.md", "INDEX.md", "../SKILLS.md"],
    "capabilities": ["dispatch", "answer-questions", "escalate", "cross-pollinate"],
    "canWriteQuestionsInAnyWorkspace": true
  },
  "tiers": [
    {
      "name": "root",
      "parallel": false,
      "agents": ["s01"]
    },
    {
      "name": "tier-1",
      "parallel": true,
      "agents": ["s02", "s03", "s04", "s05", "s06", "s07", "s08"]
    },
    {
      "name": "tier-2",
      "parallel": true,
      "agents": ["s09", "s10", "s11"]
    },
    {
      "name": "integration",
      "parallel": false,
      "agents": ["s12", "s13", "s14", "s15", "s16"]
    }
  ],
  "agents": {
    "s01": {
      "id": "s01",
      "folder": "s01/feat/wasi-feature-flags",
      "branch": "pr1/s01/feat/wasi-feature-flags",
      "anchor": "feat/wasi",
      "deps": [],
      "description": "Cargo wasi feature + build config",
      "size": "S",
      "commit": "feat: add wasi cargo feature flag and wasip2 build configuration",
      "crates": ["but"],
      "files": ["Cargo.toml", "crates/but/Cargo.toml", ".cargo/config.toml"]
    },
    "s02": {
      "id": "s02",
      "folder": "s01.s02/feat/wasi-serde-objectid",
      "branch": "pr1/s01.s02/feat/wasi-serde-objectid",
      "anchor": "pr1/s01/feat/wasi-feature-flags",
      "deps": ["s01"],
      "description": "but-serde: ObjectId abstraction (gate git2::Oid)",
      "size": "M",
      "commit": "feat: abstract ObjectId in but-serde to gate git2::Oid for WASI",
      "crates": ["but-serde"],
      "files": ["crates/but-serde/Cargo.toml", "crates/but-serde/src/"]
    },
    "s03": {
      "id": "s03",
      "folder": "s01.s03/feat/wasi-oxidize-noop",
      "branch": "pr1/s01.s03/feat/wasi-oxidize-noop",
      "anchor": "pr1/s01/feat/wasi-feature-flags",
      "deps": ["s01"],
      "description": "but-oxidize: no-op under wasi",
      "size": "S",
      "commit": "feat: make but-oxidize a no-op under wasi feature",
      "crates": ["but-oxidize"],
      "files": ["crates/but-oxidize/Cargo.toml", "crates/but-oxidize/src/"]
    },
    "s04": {
      "id": "s04",
      "folder": "s01.s04/feat/wasi-gate-tui",
