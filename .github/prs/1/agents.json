      "anchor": "pr1/s01/feat/wasi-feature-flags",
      "deps": ["s01"],
      "description": "Gate ratatui/crossterm/pager",
      "size": "M",
      "commit": "feat: gate TUI/terminal dependencies for WASI",
      "crates": ["but"],
      "files": ["crates/but/Cargo.toml", "crates/but/src/"]
    },
    "s05": {
      "id": "s05",
      "folder": "s01.s05/feat/wasi-gate-process",
